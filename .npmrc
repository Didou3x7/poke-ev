# A transitive dev-only peer conflict (vitest → vite 7 vs an optional @sveltejs/kit → vite 8
# chain) makes npm's strict peer resolver reject fresh installs. We're a Next.js app and never
# use SvelteKit, so the conflicting peer is irrelevant — accept the resolved lockfile so Vercel
# and CI installs are deterministic.
legacy-peer-deps=true
