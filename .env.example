# --- Required in production (Vercel project settings) ---
# RapidAPI key for the Pokémon TCG API (TCGGO). Server-side ONLY — never exposed to the client.
RAPIDAPI_KEY=

# Secret used to authenticate Vercel Cron invocations of /api/cron/refresh-snapshot
CRON_SECRET=

# --- Optional ---
# Vercel Blob read/write token. When present, the snapshot cron persists fresh
# data to Blob storage and pages read it with ISR. Without it, the app serves
# the bundled snapshot committed in /data/snapshot.
BLOB_READ_WRITE_TOKEN=

# Canonical site URL (defaults to https://pokeev.com)
NEXT_PUBLIC_SITE_URL=https://pokeev.com

# Plausible analytics domain (cookieless analytics — loads only if set)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=pokeev.com
